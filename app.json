{
  "expo": {
    "name": "HiTasky",
    "slug": "hitasky",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hitasky",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#18140F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hitasky.app"
    },
    "android": {
      "package": "com.hitasky.app",
      "versionCode": 1,
      "permissions": [
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#18140F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#E58A4B"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "Today",
              "label": "HiTasky · Today",
              "description": "Today's tasks at a glance",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "previewImage": "./assets/splash-icon.png",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "af11cea3-364e-4e85-9716-55af5714653f"
      }
    },
    "owner": "haseeb93"
  }
}
